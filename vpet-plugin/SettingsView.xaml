<Window x:Class="MyBuddy.VPetPlugin.SettingsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MyBuddy Bridge"
        Width="420"
        Height="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock Grid.Row="0" Text="MyBuddy bridge URL" Margin="0,0,0,4" />
    <TextBox x:Name="BridgeUrlBox" Grid.Row="1" Height="28" />

    <TextBlock Grid.Row="2" Text="Token" Margin="0,12,0,4" />
    <PasswordBox x:Name="TokenBox" Grid.Row="3" Height="28" />

    <StackPanel Grid.Row="4" Margin="0,16,0,0">
      <CheckBox x:Name="BodyStateInjectionBox" Content="body_state_injection" Margin="0,0,0,8" />
      <CheckBox x:Name="TouchEscalationBox" Content="touch_escalation" Margin="0,0,0,8" />
      <CheckBox x:Name="PhysicalProactiveBox" Content="physical_proactive" Margin="0,0,0,8" />
      <CheckBox x:Name="TodayQuietBox" Content="今天安静" />
    </StackPanel>

    <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
      <Button Content="Cancel" Width="88" Margin="0,0,8,0" Click="Cancel_Click" />
      <Button Content="Save" Width="88" Click="Save_Click" />
    </StackPanel>
  </Grid>
</Window>
