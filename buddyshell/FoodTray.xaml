<UserControl x:Class="BuddyShell.FoodTray"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Orientation="Horizontal">
        <Button Tag="congee" Content="粥" Click="Food_Click" />
        <Button Tag="curry" Content="咖喱" Click="Food_Click" Margin="3,0,0,0" />
        <Button Tag="milk_tea" Content="奶茶" Click="Food_Click" Margin="3,0,0,0" />
        <Button Tag="coffee" Content="咖啡" Click="Food_Click" Margin="3,0,0,0" />
        <Button Tag="water" Content="水" Click="Food_Click" Margin="3,0,0,0" />
    </StackPanel>
</UserControl>
