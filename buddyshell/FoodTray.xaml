<UserControl x:Class="BuddyShell.FoodTray"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <Style TargetType="Button">
            <Setter Property="Height" Value="31" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Margin" Value="2,0" />
            <Setter Property="Background" Value="#10485266" />
            <Setter Property="BorderBrush" Value="#18485266" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="#3B414D" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="15" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#20485266" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#30485266" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <Border Background="#F8F9FBFD" BorderBrush="#263C4253" BorderThickness="1"
            CornerRadius="18" Padding="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="18" ShadowDepth="4" Opacity="0.2" />
        </Border.Effect>
        <StackPanel>
            <TextBlock Text="给小布投喂" Foreground="#303541" FontWeight="SemiBold"
                       FontSize="12" Margin="2,0,0,7" />
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <Button Tag="congee" Content="粥" Click="Food_Click" />
                <Button Tag="curry" Content="咖喱" Click="Food_Click" />
                <Button Tag="milk_tea" Content="奶茶" Click="Food_Click" />
                <Button Tag="coffee" Content="咖啡" Click="Food_Click" />
                <Button Tag="water" Content="水" Click="Food_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
