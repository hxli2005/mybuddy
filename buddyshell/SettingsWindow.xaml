<Window x:Class="BuddyShell.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="小布设置" Width="410" Height="570" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Background="#F4F5F7" FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Background" Value="#F8F9FB" />
            <Setter Property="BorderBrush" Value="#D7DBE2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Background" Value="#F8F9FB" />
            <Setter Property="BorderBrush" Value="#D7DBE2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#3B414D" />
            <Setter Property="Margin" Value="0,5" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="MinWidth" Value="72" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#E5E8ED" />
            <Setter Property="Foreground" Value="#3B414D" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome" Background="{TemplateBinding Background}"
                                CornerRadius="17" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.85" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20,17">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Margin="2,0,0,13">
            <TextBlock Text="设置" FontSize="21" FontWeight="SemiBold" Foreground="#272C35" />
            <TextBlock Text="连接与桌宠行为" FontSize="11" Foreground="#7A818D" Margin="0,2,0,0" />
        </StackPanel>

        <Border Grid.Row="1" Background="White" BorderBrush="#E1E4E9" BorderThickness="1"
                CornerRadius="14" Padding="14" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Text="连接" FontWeight="SemiBold" Foreground="#303541" Margin="0,0,0,9" />
                <TextBlock Grid.Row="1" Text="桥地址" FontSize="11" Foreground="#6E7581" />
                <TextBox x:Name="BridgeUrl" Grid.Row="2" Margin="0,4,0,9" />
                <Grid Grid.Row="3">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="访问令牌" FontSize="11" Foreground="#6E7581" />
                    <PasswordBox x:Name="BridgeToken" Grid.Row="1" Margin="0,4,0,0" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="White" BorderBrush="#E1E4E9" BorderThickness="1"
                CornerRadius="14" Padding="14,10" Margin="0,0,0,10">
            <StackPanel>
                <TextBlock Text="行为" FontWeight="SemiBold" Foreground="#303541" Margin="0,0,0,3" />
                <WrapPanel>
                    <CheckBox x:Name="PhysioInjection" Content="生理状态注入" Width="166" />
                    <CheckBox Content="TTS（预留）" IsEnabled="False" />
                </WrapPanel>
                <TextBlock Text="动画引擎：状态机帧播放器" Foreground="#858B95" FontSize="10" Margin="0,3,0,0" />
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Background="#EAF0F8" CornerRadius="12" Padding="12,9">
            <StackPanel>
                <TextBlock x:Name="ServerClock" Text="服务端时间：尚未连接" Foreground="#46566F" FontSize="11" />
                <TextBlock x:Name="Offset" Margin="0,3,0,0" Text="验收偏移：未知" Foreground="#46566F" FontSize="11" />
                <TextBlock Margin="0,3,0,0" Foreground="#7B8491" FontSize="10"
                           Text="偏移由后端启动变量控制，修改后需重启后端。" />
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="4" Margin="2,10,2,0" TextWrapping="Wrap" FontSize="10"
                   Foreground="#7A818D" VerticalAlignment="Top">
            VPet 素材版权归虚拟主播模拟器制作组；当前仅按非商用条件使用。
            <Hyperlink NavigateUri="https://github.com/LorisYounger/VPet"
                       RequestNavigate="AboutLink_RequestNavigate">项目主页</Hyperlink>
        </TextBlock>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" IsCancel="True" Style="{StaticResource ActionButton}" />
            <Button Content="保存" Click="Save_Click" Margin="8,0,0,0"
                    Style="{StaticResource ActionButton}" Background="#46566F" Foreground="White" />
        </StackPanel>
    </Grid>
</Window>
