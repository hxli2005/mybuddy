<Window x:Class="BuddyShell.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="小布设置" Width="430" Height="430" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Text="桥地址" />
        <TextBox x:Name="BridgeUrl" Grid.Row="1" Margin="0,5,0,10" />
        <TextBlock Grid.Row="2" Text="访问令牌" />
        <PasswordBox x:Name="BridgeToken" Grid.Row="3" Margin="0,5,0,10" />
        <StackPanel Grid.Row="4">
            <CheckBox x:Name="PhysioInjection" Content="生理状态注入" />
            <CheckBox x:Name="TouchEscalation" Content="触摸升格" Margin="0,5,0,0" />
            <CheckBox x:Name="PhysicalProactive" Content="允许主动气泡" Margin="0,5,0,0" />
            <CheckBox x:Name="ForceFramePlayer" Content="使用兼容帧播放器（重启生效）" Margin="0,5,0,0" />
            <CheckBox Content="TTS（v2 占位）" IsEnabled="False" Margin="0,5,0,0" />
        </StackPanel>
        <Border Grid.Row="5" Margin="0,14,0,0" Padding="9" Background="#FFF2F4F7" CornerRadius="8">
            <StackPanel>
                <TextBlock x:Name="ServerClock" Text="服务端时间：尚未连接" />
                <TextBlock x:Name="Offset" Margin="0,4,0,0" Text="验收偏移：未知" />
                <TextBlock Margin="0,4,0,0" Foreground="#666" Text="偏移只由后端启动变量控制，修改后需重启后端。" />
            </StackPanel>
        </Border>
        <TextBlock Grid.Row="6" Margin="0,14,0,0" TextWrapping="Wrap">
            素材版权归虚拟主播模拟器制作组；本项目仅按非商用条件使用。商业化前需另行取得授权。
            <Hyperlink NavigateUri="https://github.com/LorisYounger/VPet"
                       RequestNavigate="AboutLink_RequestNavigate">项目主页</Hyperlink>
        </TextBlock>
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" IsCancel="True" Padding="14,5" />
            <Button Content="保存" Click="Save_Click" Padding="14,5" Margin="8,0,0,0" />
        </StackPanel>
    </Grid>
</Window>
