<UserControl x:Class="BuddyShell.Bubble"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <Border x:Name="SpeechBorder" Visibility="Collapsed" Padding="12,9"
                Background="#ECFFFFFF" BorderBrush="#553C4253" BorderThickness="1"
                CornerRadius="15" MaxWidth="320">
            <TextBlock x:Name="SpeechText" TextWrapping="Wrap" Foreground="#242833"
                       FontSize="14" />
        </Border>
        <ItemsControl x:Name="PersistentCards" Margin="0,6,0,0">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="#F7FFF2D8" BorderBrush="#88C99A35"
                            BorderThickness="1" CornerRadius="10" Padding="9" Margin="0,3">
                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="#574100" />
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
