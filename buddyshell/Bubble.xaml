<UserControl x:Class="BuddyShell.Bubble"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel>
        <Border x:Name="SpeechBorder" Visibility="Collapsed" Padding="11,8"
                Background="#F7F9FBFD" BorderBrush="#303C4253" BorderThickness="1"
                CornerRadius="14" MaxWidth="306">
            <Border.Effect>
                <DropShadowEffect BlurRadius="14" ShadowDepth="3" Opacity="0.16" />
            </Border.Effect>
            <TextBlock x:Name="SpeechText" TextWrapping="Wrap" Foreground="#242833"
                       FontSize="13" />
        </Border>
        <ItemsControl x:Name="PersistentCards" Margin="0,6,0,0">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="#F8FFF7DA" BorderBrush="#54C99A35"
                            BorderThickness="1" CornerRadius="11" Padding="8" Margin="0,3">
                        <TextBlock Text="{Binding}" TextWrapping="Wrap" Foreground="#574100"
                                   FontSize="12" />
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</UserControl>
