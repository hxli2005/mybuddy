<UserControl x:Class="BuddyShell.ChatPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="#F2FFFFFF" CornerRadius="14" Padding="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <ListBox x:Name="History" BorderThickness="0" Background="Transparent"
                     MaxHeight="150" ScrollViewer.VerticalScrollBarVisibility="Auto" />
            <DockPanel Grid.Row="1" Margin="0,6,0,0">
                <Button DockPanel.Dock="Right" Content="发送" Padding="12,4"
                        Click="Send_Click" />
                <TextBox x:Name="Input" Margin="0,0,6,0" MinHeight="30"
                         VerticalContentAlignment="Center" KeyDown="Input_KeyDown" />
            </DockPanel>
        </Grid>
    </Border>
</UserControl>
